# Agentic Messaging — environment configuration
#
# The app runs fully on a built-in MOCK backend with NO env vars set.
# To switch the data layer to a real Supabase project, set all three:

EXPO_PUBLIC_USE_SUPABASE=false
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Apple Messages for Business test conversation (MSP test account).
# Override if the biz id changes; falls back to the built-in default.
EXPO_PUBLIC_AMB_BIZ_ID=914e49f4-2b03-4e2b-987f-8c8f45e40294
